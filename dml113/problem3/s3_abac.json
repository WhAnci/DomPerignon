{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowS3ListBucket",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": "arn:aws:s3:::<bucket-name>",
      "Condition": {
        "StringEquals": {
          "s3:prefix": ["${aws:PrincipalTag/Department}/"]
        }
      }
    },
    {
      "Sid": "AllowS3ObjectAccessByDepartmentTag",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::<bucket-name>/${aws:PrincipalTag/Department}/*"
    }
  ]
}
